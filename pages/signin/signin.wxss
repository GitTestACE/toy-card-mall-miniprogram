/* pages/signin/signin.wxss */
.signin-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.points {
  font-size: 28rpx;
  opacity: 0.9;
}

.continuous-days {
  text-align: center;
  margin-bottom: 30rpx;
}

.continuous-days .label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

.continuous-days .days {
  font-size: 80rpx;
  font-weight: bold;
}

.next-bonus {
  text-align: center;
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 30rpx;
}

.signin-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #667eea;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.signin-btn.signed {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
}

.signin-btn[disabled] {
  opacity: 1;
}

.makeup-info {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  opacity: 0.8;
}

.reward-card, .calendar-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.reward-list {
  display: flex;
  justify-content: space-around;
}

.reward-item {
  text-align: center;
}

.reward-item .days {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.reward-item .points {
  font-size: 32rpx;
  color: #ff9500;
  font-weight: bold;
}

.reward-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}
