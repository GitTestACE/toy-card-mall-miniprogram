<!-- pages/signin/signin.wxml -->
<view class="signin-container">
  <!-- 签到状态卡片 -->
  <view class="status-card">
    <view class="status-header">
      <text class="title">今日签到</text>
      <text class="points">💎 {{currentPoints}} 积分</text>
    </view>
    
    <view class="continuous-days">
      <text class="label">连续签到</text>
      <text class="days">{{continuousDays}} 天</text>
    </view>

    <view class="next-bonus" wx:if="{{nextBonus}}">
      <text>再签到 {{nextBonus.daysRequired - continuousDays}} 天可获得 {{nextBonus.points}} 积分</text>
    </view>

    <!-- 签到按钮 -->
    <button 
      class="signin-btn {{signedToday ? 'signed' : ''}}" 
      bindtap="handleSignIn"
      disabled="{{signedToday || loading}}">
      {{signedToday ? '已签到' : '立即签到'}}
    </button>

    <!-- 补签次数 -->
    <view class="makeup-info" wx:if="{{makeUpCount > 0}}">
      <text>本月还可补签 {{makeUpCount}} 次</text>
    </view>
  </view>

  <!-- 奖励说明 -->
  <view class="reward-card">
    <view class="card-title">签到奖励</view>
    <view class="reward-list">
      <view class="reward-item" wx:for="{{rewardConfig}}" wx:key="days">
        <text class="days">{{item.days}} 天</text>
        <text class="points">+{{item.points}} 积分</text>
      </view>
    </view>
    <view class="reward-tip">基础签到每日 +2 积分</view>
  </view>

  <!-- 签到日历 -->
  <view class="calendar-card">
    <view class="card-title">签到日历</view>
    <sign-calendar 
      signedDates="{{signedDates}}" 
      makeUpCount="{{makeUpCount}}"
      bind:makeUp="handleMakeUp"
    />
  </view>
</view>
