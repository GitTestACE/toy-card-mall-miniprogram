<!-- pages/index/index.wxml -->
<view class="index-container">
  <!-- 抽奖入口 -->
  <view class="lottery-banner" bindtap="goLottery">
    <view class="lottery-icon">🎰</view>
    <view class="lottery-info">
      <view class="lottery-title">积分抽奖</view>
      <view class="lottery-desc">10积分抽好礼</view>
    </view>
    <view class="lottery-btn">立即参与</view>
  </view>

  <!-- 热门商品 -->
  <view class="section" wx:if="{{hotGoods.length > 0}}">
    <view class="section-title">🔥 热门商品</view>
    <scroll-view class="hot-scroll" scroll-x>
      <view class="hot-item" wx:for="{{hotGoods}}" wx:key="id">
        <image class="hot-img" src="{{item.imgUrl}}" mode="aspectFill" />
        <view class="hot-name">{{item.name}}</view>
        <view class="hot-price">{{item.price}}积分</view>
        <button class="hot-btn" bindtap="onAddCart" data-id="{{item.id}}">+</button>
      </view>
    </scroll-view>
  </view>

  <!-- 分类标签 -->
  <view class="tabs">
    <view class="tab {{currentType === '' ? 'active' : ''}}" bindtap="onSwitchType" data-type="">全部</view>
    <view class="tab {{currentType === 'toy' ? 'active' : ''}}" bindtap="onSwitchType" data-type="toy">🧸 玩具</view>
    <view class="tab {{currentType === 'card' ? 'active' : ''}}" bindtap="onSwitchType" data-type="card">🎴 卡片</view>
  </view>

  <!-- 商品列表 -->
  <view class="goods-list">
    <view class="goods-item" wx:for="{{goodsList}}" wx:key="id">
      <image class="goods-img" src="{{item.imgUrl}}" mode="aspectFill" />
      <view class="goods-info">
        <view class="goods-name">{{item.name}}</view>
        <view class="goods-desc">{{item.description}}</view>
        <view class="goods-bottom">
          <view class="goods-price">{{item.price}} 积分</view>
          <button class="add-btn" bindtap="onAddCart" data-id="{{item.id}}">加入购物车</button>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{goodsList.length === 0}}">
    <text>暂无商品</text>
  </view>

  <!-- 底部导航 -->
  <view class="tab-bar">
    <view class="tab-item active">首页</view>
    <view class="tab-item" bindtap="goCart">购物车</view>
    <view class="tab-item" bindtap="goUser">我的</view>
  </view>
</view>
