/* pages/index/index.wxss */
.index-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.hot-scroll { white-space: nowrap; width: 100%; }

.hot-item {
  display: inline-block;
  width: 180rpx;
  margin-right: 20rpx;
  text-align: center;
}

.hot-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; }

.hot-name {
  font-size: 24rpx;
  color: #333;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-price { font-size: 24rpx; color: #ff6b6b; font-weight: bold; }

.hot-btn {
  background: #ff6b6b;
  color: #fff;
  font-size: 28rpx;
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  padding: 0;
  border-radius: 50%;
  margin: 10rpx auto 0;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx;
  gap: 20rpx;
}

.tab {
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}

.tab.active { background: #ff6b6b; color: #fff; }

.goods-list { padding: 20rpx; display: flex; flex-direction: column; gap: 20rpx; }

.goods-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.goods-img { width: 200rpx; height: 200rpx; flex-shrink: 0; }

.goods-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name { font-size: 30rpx; font-weight: bold; color: #333; }

.goods-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; }

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price { color: #ff6b6b; font-size: 32rpx; font-weight: bold; }

.add-btn {
  background: #ff6b6b;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  margin: 0;
}

.empty { text-align: center; padding: 100rpx; color: #999; }

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  border-top: 2rpx solid #eee;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #999;
}

.tab-item.active { color: #ff6b6b; font-weight: bold; }
