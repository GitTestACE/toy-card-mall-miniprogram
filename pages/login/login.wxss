/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 60rpx;
}

.form {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.1);
}

.input {
  border: 2rpx solid #eee;
  border-radius: 40rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.avatar-section {
  margin-bottom: 40rpx;
}

.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.avatars {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.avatar-item {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid #eee;
}

.avatar-item.selected {
  border-color: #ff6b6b;
}

.avatar-item image {
  width: 100%;
  height: 100%;
}

.btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  color: #fff;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
}
