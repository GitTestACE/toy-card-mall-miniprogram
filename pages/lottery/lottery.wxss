/* pages/lottery/lottery.wxss */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.lottery-container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 头部信息 */
.header {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.activity-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 10rpx;
}

.activity-desc {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-item .label {
  font-size: 24rpx;
  color: #999;
}

.info-item .value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-top: 10rpx;
}

/* 抽奖转盘 */
.wheel-container {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  margin: 0 auto 40rpx;
}

.wheel {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #ff9a9e 100%);
  box-shadow: 0 10rpx 40rpx rgba(255, 107, 107, 0.4);
  position: relative;
  transition: transform 3s cubic-bezier(0.25, 0.1, 0.25, 1);
  overflow: hidden;
}

.prize-item {
  position: absolute;
  width: 120rpx;
  height: 200rpx;
  left: 50%;
  top: 50%;
  transform-origin: center bottom;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 20rpx;
}

.prize-image {
  width: 80rpx;
  height: 80rpx;
}

.prize-name {
  font-size: 20rpx;
  color: #333;
  margin-top: 10rpx;
  text-align: center;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pointer {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.pointer:active {
  transform: translate(-50%, -50%) scale(0.95);
}

.pointer-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

/* 奖品列表 */
.prize-list {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.prize-scroll {
  width: 100%;
  white-space: nowrap;
}

.prize-cards {
  display: flex;
  gap: 20rpx;
}

.prize-card {
  width: 200rpx;
  background: #f8f8f8;
  border-radius: 15rpx;
  padding: 20rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
}

.card-image {
  width: 120rpx;
  height: 120rpx;
}

.card-name {
  font-size: 26rpx;
  color: #333;
  margin-top: 10rpx;
  text-align: center;
}

.card-points {
  font-size: 22rpx;
  color: #ff6b6b;
  margin-top: 8rpx;
}

/* 抽奖记录 */
.records-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.records-list {
  max-height: 400rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.record-item:last-child {
  border-bottom: none;
}

.record-prize {
  font-size: 28rpx;
  color: #333;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.no-records {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 底部导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  box-shadow: 0 -5rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  font-size: 28rpx;
  color: #999;
}

.tab-item.active {
  color: #ff6b6b;
  font-weight: bold;
}

/* 结果弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
}

.result-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  z-index: 101;
  overflow: hidden;
  animation: modalShow 0.3s ease;
}

@keyframes modalShow {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.8);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

.modal-content {
  padding: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.result-image {
  width: 200rpx;
  height: 200rpx;
}

.result-name {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: bold;
  margin-top: 20rpx;
}

.result-points {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.confirm-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.confirm-btn:active {
  opacity: 0.8;
}
