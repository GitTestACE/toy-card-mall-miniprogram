<!-- pages/user/user.wxml -->
<view class="user-container">
  <view class="user-header">
    <image class="avatar" src="{{userInfo.avatar || defaultAvatar}}" mode="aspectFill" />
    <view class="nickname">{{userInfo.nickname}}</view>
    <view class="points">
      <text class="points-label">当前积分</text>
      <text class="points-value">{{userInfo.points}}</text>
    </view>
  </view>
  <view class="menu-list">
    <view class="menu-item" bindtap="goOrder"><text>📦 我的订单</text></view>
    <view class="menu-item" bindtap="onRefreshPoints"><text>🔄 刷新积分</text></view>
    <view class="menu-item" bindtap="goIndex"><text>🏠 返回首页</text></view>
    <view class="menu-item" bindtap="onLogout"><text>🚪 退出登录</text></view>
  </view>
  <view class="tips">
    <view class="tips-title">💡 温馨提示</view>
    <view>• 新用户注册自动获得1000积分</view>
    <view>• 商品用积分购买，积分不足无法支付</view>
  </view>
  <view class="tab-bar">
    <view class="tab-item" bindtap="goIndex">首页</view>
    <view class="tab-item" bindtap="goCart">购物车</view>
    <view class="tab-item active">我的</view>
  </view>
</view>
