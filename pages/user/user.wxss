/* pages/user/user.wxss */
.user-container { min-height: 100vh; background: #f5f5f5; padding-bottom: 120rpx; }
.user-header { background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%); padding: 60rpx 40rpx; text-align: center; color: #fff; }
.avatar { width: 140rpx; height: 140rpx; border-radius: 50%; border: 6rpx solid rgba(255,255,255,0.3); margin-bottom: 20rpx; }
.nickname { font-size: 36rpx; font-weight: bold; margin-bottom: 20rpx; }
.points { background: rgba(255,255,255,0.2); display: inline-block; padding: 16rpx 40rpx; border-radius: 30rpx; }
.points-label { font-size: 26rpx; margin-right: 10rpx; }
.points-value { font-size: 40rpx; font-weight: bold; }
.menu-list { background: #fff; margin: 20rpx; border-radius: 16rpx; overflow: hidden; }
.menu-item { padding: 30rpx; border-bottom: 2rpx solid #f5f5f5; font-size: 28rpx; }
.menu-item:last-child { border-bottom: none; }
.tips { margin: 20rpx; padding: 30rpx; background: #fff; border-radius: 16rpx; font-size: 24rpx; color: #666; line-height: 2; }
.tips-title { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 10rpx; }
.tab-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 100rpx; background: #fff; display: flex; border-top: 2rpx solid #eee; }
.tab-item { flex: 1; display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: #999; }
.tab-item.active { color: #ff6b6b; font-weight: bold; }
