/* components/SignInCalendar/index.wxss */
.calendar {
  padding: 10rpx 0;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.month {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.hint {
  font-size: 24rpx;
  color: #ff9500;
}

.weekdays {
  display: flex;
  margin-bottom: 10rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.day {
  width: 14.28%;
  height: 70rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}

.day.empty {
  opacity: 0;
}

.day.signed .day-text {
  color: #34c759;
  font-weight: bold;
}

.day.missed .day-text {
  color: #999;
}

.day.future .day-text {
  color: #e5e5e5;
}

.day.missed::after {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: #ff3b30;
  border-radius: 50%;
  bottom: 10rpx;
}

.check-icon {
  position: absolute;
  top: 4rpx;
  right: 8rpx;
  font-size: 18rpx;
  color: #34c759;
}

.day-text {
  font-size: 26rpx;
}

.legend {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot.signed {
  background: #34c759;
}

.dot.missed {
  background: #ff3b30;
}

.dot.future {
  background: #e5e5e5;
}
